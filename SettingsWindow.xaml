<ui:FluentWindow x:Class="NotiFlow.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:pages="clr-namespace:NotiFlow.Views.Pages"
                 Title="弹幕通知"
                 Height="768"
                 Width="1024"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    
    <!-- 整个页面划分为两行：顶部系统标题栏、剩余区域留给导航树 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 自定义原生的 Win11 沉浸式标题栏 -->
        <ui:TitleBar
            Grid.Row="0"
            Title="弹幕通知"/>

        <!-- 基于 WPF-UI 的主导航架构 -->
        <ui:NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="False"
            OpenPaneLength="180">
            
            <ui:NavigationView.Resources>
                <Style TargetType="Separator">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </ui:NavigationView.Resources>

            <ui:NavigationView.MenuItems>
                <!-- 自定义页 -->
                <ui:NavigationViewItem
                    Content="自定义"
                    Icon="{ui:SymbolIcon DesignIdeas24}"
                    TargetPageType="{x:Type pages:CustomPage}" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <!-- 设置页 -->
                <ui:NavigationViewItem
                    Content="设置"
                    Icon="{ui:SymbolIcon Settings24}"
                    TargetPageType="{x:Type pages:SettingsPage}" />
                <!-- 关于页 -->
                <ui:NavigationViewItem
                    Content="关于"
                    Icon="{ui:SymbolIcon Info24}"
                    TargetPageType="{x:Type pages:AboutPage}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
