<Window x:Class="NotiFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rendering="clr-namespace:NotiFlow.Rendering"
        Title="NotiFlow"
        WindowState="Normal"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Style="{x:Null}"
        Loaded="Window_Loaded">
    <rendering:BarrageEngineHost x:Name="EngineHost" />
</Window>
