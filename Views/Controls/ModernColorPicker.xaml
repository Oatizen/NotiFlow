<UserControl x:Class="NotiFlow.Views.Controls.ModernColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Width="320" Height="420"
             Background="{DynamicResource ApplicationBackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 (类似于 TranslucentTB) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <RadioButton x:Name="TabSwatches" Grid.Column="0" IsChecked="True" GroupName="PickerTabs" Style="{DynamicResource PickerTabButtonStyle}" Click="Tab_Click">
                <ui:SymbolIcon Symbol="Grid24" FontSize="20" />
            </RadioButton>
            <RadioButton x:Name="TabSpectrum" Grid.Column="1" GroupName="PickerTabs" Style="{DynamicResource PickerTabButtonStyle}" Click="Tab_Click">
                <ui:SymbolIcon Symbol="Color24" FontSize="20" />
            </RadioButton>
            <RadioButton x:Name="TabSliders" Grid.Column="2" GroupName="PickerTabs" Style="{DynamicResource PickerTabButtonStyle}" Click="Tab_Click">
                <ui:SymbolIcon Symbol="Options24" FontSize="20" />
            </RadioButton>
            
            <!-- 底部蓝线指示器将在代码中处理，或用简单的边框效果 -->
        </Grid>

        <!-- 内容区域 -->
        <Grid Grid.Row="1" Margin="12,12,12,0">
            
            <!-- 1. Swatches (预设色板) -->
            <Grid x:Name="SwatchesView" Visibility="Visible">
                <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalAlignment="Center">
                    <ItemsControl ItemsSource="{Binding PresetColors, RelativeSource={RelativeSource AncestorType=UserControl}}" HorizontalContentAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Background="{Binding Brush}"
                                        Command="{Binding SelectPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Height="32" Padding="0" Margin="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="0" />
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            
            <!-- 2. Spectrum (拾色盘) -->
            <Grid x:Name="SpectrumView" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="32" />
                </Grid.ColumnDefinitions>
                
                <!-- 亮度滑块 (Value) -->
                <Grid Grid.Column="0">
                    <Border CornerRadius="8" BorderThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="ValueSliderTopColor" Color="Red" Offset="0" />
                                <GradientStop Color="Black" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Slider x:Name="ValueSlider" Orientation="Vertical" Minimum="0" Maximum="1" Value="1" 
                            Style="{DynamicResource ColorSliderStyle}" ValueChanged="SpectrumSlider_ValueChanged" />
                </Grid>

                <!-- 色相/饱和度 拾取区 -->
                <Grid Grid.Column="2" x:Name="ColorAreaGrid" MouseLeftButtonDown="ColorArea_MouseLeftButtonDown" MouseMove="ColorArea_MouseMove" MouseLeftButtonUp="ColorArea_MouseLeftButtonUp" SizeChanged="ColorAreaGrid_SizeChanged" Background="Transparent" ClipToBounds="True">
                    <Border CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFF0000" Offset="0" />
                                <GradientStop Color="#FFFFFF00" Offset="0.16666" />
                                <GradientStop Color="#FF00FF00" Offset="0.33333" />
                                <GradientStop Color="#FF00FFFF" Offset="0.5" />
                                <GradientStop Color="#FF0000FF" Offset="0.66666" />
                                <GradientStop Color="#FFFF00FF" Offset="0.83333" />
                                <GradientStop Color="#FFFF0000" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="White" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    
                    <Canvas>
                        <Ellipse x:Name="ColorThumb" Width="16" Height="16" Stroke="White" StrokeThickness="2" Fill="Transparent" 
                                 RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False">
                            <Ellipse.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.5" />
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="ColorThumbTransform" X="-8" Y="-8" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Canvas>
                </Grid>

                <!-- 透明度滑块 (Alpha) -->
                <Grid Grid.Column="4">
                    <Border CornerRadius="8" Background="{DynamicResource CheckerboardBrush}" />
                    <Border CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="AlphaSliderTopColor" Color="Red" Offset="0" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Slider x:Name="AlphaSlider" Orientation="Vertical" Minimum="0" Maximum="255" Value="255" 
                            Style="{DynamicResource ColorSliderStyle}" ValueChanged="SpectrumSlider_ValueChanged" />
                </Grid>
                
                <!-- 色相滑块 (Hue) 放到底部 -->
                <Grid Grid.Column="0" Grid.ColumnSpan="5" VerticalAlignment="Bottom" Height="24" Margin="0,0,0,-36">
                    <Border CornerRadius="12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF0000" Offset="0.00" />
                                <GradientStop Color="#FFFF00" Offset="0.17" />
                                <GradientStop Color="#00FF00" Offset="0.33" />
                                <GradientStop Color="#00FFFF" Offset="0.50" />
                                <GradientStop Color="#0000FF" Offset="0.67" />
                                <GradientStop Color="#FF00FF" Offset="0.83" />
                                <GradientStop Color="#FF0000" Offset="1.00" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Slider x:Name="HueSlider" Minimum="0" Maximum="360" Value="0" 
                            Style="{DynamicResource ColorSliderStyle}" ValueChanged="HueSlider_ValueChanged" />
                </Grid>
            </Grid>

            <!-- 3. Sliders (滑块与文本) -->
            <Grid x:Name="SlidersView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <ui:TextBox x:Name="HexTextBox" Grid.Column="0" Grid.ColumnSpan="3" TextChanged="HexTextBox_TextChanged" />
                </Grid>
                
                <StackPanel Grid.Row="1">
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="R" VerticalAlignment="Center" FontWeight="Bold" />
                        <Slider x:Name="RSlider" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="RgbSlider_ValueChanged" />
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="G" VerticalAlignment="Center" FontWeight="Bold" />
                        <Slider x:Name="GSlider" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="RgbSlider_ValueChanged" />
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="B" VerticalAlignment="Center" FontWeight="Bold" />
                        <Slider x:Name="BSlider" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="RgbSlider_ValueChanged" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="A" VerticalAlignment="Center" FontWeight="Bold" />
                        <Slider x:Name="ASlider" Grid.Column="1" Minimum="0" Maximum="255" ValueChanged="RgbSlider_ValueChanged" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- 底部吸管区 -->
        <Grid Grid.Row="2" Background="{DynamicResource ApplicationBackgroundBrush}">
            <!-- 分割线 -->
            <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" VerticalAlignment="Top" />
            
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <ui:Button x:Name="EyedropperButton" Grid.Column="0" Appearance="Transparent" Click="EyedropperButton_Click" ToolTip="吸取屏幕颜色">
                    <ui:SymbolIcon Symbol="ColorBackground20" FontSize="20" />
                </ui:Button>
                
                <Border Grid.Column="1" Margin="12,0" CornerRadius="4" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush x:Name="PreviewColorBrush" Color="Red" />
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    
    <UserControl.Resources>
        <!-- 棋盘格画刷 (用于透明度背景) -->
        <DrawingBrush x:Key="CheckerboardBrush" Viewport="0,0,16,16" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#E5E5E5">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,16,16" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#CCCCCC">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,8,8" />
                                <RectangleGeometry Rect="8,8,8,8" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Tab RadioButton 样式 -->
        <Style x:Key="PickerTabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" VerticalAlignment="Bottom" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 透明滑块样式 -->
        <Style x:Key="ColorSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Stroke="White" StrokeThickness="3" Fill="Transparent">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.5" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
</UserControl>
