<ui:FluentWindow x:Class="NotiFlow.Views.Windows.UpdateDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="检查更新"
                 Width="480"
                 Height="300"
                 MinWidth="420"
                 MinHeight="220"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- 标题栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 内容区 -->
            <RowDefinition Height="*"/>
            <!-- 按钮区 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Grid.Row="0" Title="检查更新" ShowMinimize="False" ShowMaximize="False"/>

        <!-- 内容区 -->
        <Grid Grid.Row="1" Margin="24,8,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 弹窗标题 -->
            <ui:TextBlock x:Name="DialogTitleText"
                          Grid.Row="0"
                          FontTypography="BodyStrong"
                          FontWeight="SemiBold"
                          TextWrapping="Wrap"
                          Margin="0,0,0,12"/>

            <!-- 弹窗正文 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="DialogContentText"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           LineHeight="22"/>
            </ScrollViewer>
        </Grid>

        <!-- 底部按钮区 -->
        <Border Grid.Row="2"
                Padding="24,16"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ui:Button Content="确定"
                           Appearance="Primary"
                           Padding="24,6"
                           Click="OkButton_Click"/>
                <ui:Button Content="GitHub仓库"
                           Appearance="Secondary"
                           Padding="24,6"
                           Margin="12,0,0,0"
                           Click="GitHubButton_Click"/>
                <ui:Button Content="Gitee仓库"
                           Appearance="Secondary"
                           Padding="24,6"
                           Margin="12,0,0,0"
                           Click="GiteeButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
