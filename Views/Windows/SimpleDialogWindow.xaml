<ui:FluentWindow x:Class="NotiFlow.Views.Windows.SimpleDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="提示"
                 Width="420"
                 Height="220"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- 标题栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 内容区 -->
            <RowDefinition Height="*"/>
            <!-- 按钮区 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Grid.Row="0" Title="提示" ShowMinimize="False" ShowMaximize="False"/>

        <!-- 内容区 -->
        <Grid Grid.Row="1" Margin="24,8,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 弹窗标题 -->
            <ui:TextBlock x:Name="DialogTitleText"
                          Grid.Row="0"
                          FontTypography="BodyStrong"
                          FontWeight="SemiBold"
                          TextWrapping="Wrap"
                          Margin="0,0,0,12"/>

            <!-- 弹窗正文 -->
            <TextBlock x:Name="DialogContentText"
                       Grid.Row="1"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       LineHeight="22"/>
        </Grid>

        <!-- 底部按钮区 -->
        <Border Grid.Row="2"
                Padding="24,16"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ui:Button Content="确定"
                           Appearance="Primary"
                           Padding="24,6"
                           Click="OkButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
