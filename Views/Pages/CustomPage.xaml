<Page x:Class="NotiFlow.Views.Pages.CustomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="自定义"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" CanContentScroll="False" Background="Transparent">
        <StackPanel Margin="24,12,24,24" Background="Transparent">

            <!-- 页面大标题 -->
            <Grid Margin="0,0,0,24">
                <ui:TextBlock FontTypography="TitleLarge" Text="自定义" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ui:Button x:Name="ToggleWorkButton" Appearance="Primary" Content="开启" Click="ToggleWorkButton_Click" Padding="24,0" Height="36" MinWidth="100" Margin="0,0,12,0"/>
                    <Grid>
                        <ui:Button x:Name="HelpButton" Icon="{ui:SymbolIcon QuestionCircle24}" Appearance="Transparent" Height="36" Width="36" Padding="0" Click="HelpButton_Click"/>
                        <ui:Flyout x:Name="HelpFlyout" Placement="Bottom">
                            <ui:TextBlock Text="仅支持在窗口模式或无边框窗口模式的应用上显示通知，不支持以全屏模式运行的应用" TextWrapping="Wrap" MaxWidth="300" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </ui:Flyout>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- 第一区域：弹幕预览区 -->
            <StackPanel Margin="0,0,0,24">
                <Grid Margin="0,0,0,16">
                    <ui:TextBlock Text="弹幕预览" FontTypography="BodyStrong"/>
                    <ui:TextBlock Text="实时预览" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <Border Height="200" Background="#1c1c1c" CornerRadius="12" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Grid24" FontSize="20" Margin="0,0,12,0" Foreground="White" />
                        <TextBlock Text="这是一段测试弹幕" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 第二区域：双列设置项 -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左列：字体设置 -->
                <Border Grid.Column="0" VerticalAlignment="Top" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <!-- 区域标题 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="TextFont24" FontSize="20" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" Margin="0,0,8,0"/>
                            <ui:TextBlock FontTypography="BodyStrong" Text="字体设置" FontSize="16"/>
                        </StackPanel>

                        <ui:TextBlock Text="字体" Margin="0,0,0,8"/>
                        <ComboBox SelectedIndex="0" Margin="0,0,0,20" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Inter"/>
                            <ComboBoxItem Content="微软雅黑"/>
                        </ComboBox>

                        <Grid Margin="0,0,0,8">
                            <ui:TextBlock Text="字体大小"/>
                            <ui:TextBlock x:Name="FontSizeText" Text="24px" HorizontalAlignment="Right" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="FontSizeSlider" Minimum="12" Maximum="64" Value="24" Margin="0,0,0,20" ValueChanged="FontSizeSlider_ValueChanged"/>

                        <ui:TextBlock Text="字重" Margin="0,0,0,8"/>
                        <!-- ToggleButton 组模拟 Segmented Control -->
                        <Grid Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ui:Button x:Name="FontWeightNormalBtn" Grid.Row="0" Content="常规" Appearance="Primary" HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="FontWeightNormalBtn_Click"/>
                            <ui:Button x:Name="FontWeightBoldBtn" Grid.Row="1" Content="加粗" Appearance="Transparent" HorizontalAlignment="Stretch" Click="FontWeightBoldBtn_Click"/>
                        </Grid>

                        <ui:TextBlock Text="字体样式" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:Button x:Name="FontStyleItalicBtn" Grid.Column="0" Content="斜体" Appearance="Transparent" HorizontalAlignment="Stretch" Click="FontStyleItalicBtn_Click"/>
                            <ui:Button x:Name="FontStyleUnderlineBtn" Grid.Column="2" Content="下划线" Appearance="Transparent" HorizontalAlignment="Stretch" Click="FontStyleUnderlineBtn_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 右列：外观设置 -->
                <Border Grid.Column="2" VerticalAlignment="Top" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <!-- 区域标题 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="Color24" FontSize="20" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" Margin="0,0,8,0"/>
                            <ui:TextBlock FontTypography="BodyStrong" Text="外观" FontSize="16"/>
                        </StackPanel>

                        <ui:TextBlock Text="颜色选择器" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" Background="White" CornerRadius="8" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,0,12,0"/>
                            <ui:TextBox Grid.Column="1" Text="#FFFFFF" IsReadOnly="True" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <ui:TextBlock Text="不透明度"/>
                            <ui:TextBlock x:Name="OpacityText" Text="85%" HorizontalAlignment="Right" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" Value="85" Margin="0,0,0,20" ValueChanged="OpacitySlider_ValueChanged"/>

                        <Grid Margin="0,0,0,8">
                            <ui:TextBlock Text="背景不透明度"/>
                            <ui:TextBlock x:Name="BackgroundOpacityText" Text="20%" HorizontalAlignment="Right" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="BackgroundOpacitySlider" Minimum="0" Maximum="100" Value="20" Margin="0,0,0,24" ValueChanged="BackgroundOpacitySlider_ValueChanged"/>

                        <Grid Margin="0,0,0,16">
                            <StackPanel>
                                <ui:TextBlock Text="显示应用图标"/>
                                <ui:TextBlock Text="弹幕前显示应用图标" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="True"/>
                        </Grid>

                        <Grid>
                            <StackPanel>
                                <ui:TextBlock Text="显示应用名称"/>
                                <ui:TextBlock Text="弹幕前显示应用名称" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="False"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </Grid>

            <!-- 第三区域：动画设置 -->
            <Border VerticalAlignment="Top" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="Flash24" FontSize="20" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" Margin="0,0,8,0"/>
                        <ui:TextBlock FontTypography="BodyStrong" Text="动画" FontSize="16"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Grid.Column="0" Text="动画速度" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <Slider x:Name="SpeedSlider" Grid.Column="1" Minimum="5" Maximum="30" Value="12" Margin="0,0,16,0" VerticalAlignment="Center" ValueChanged="SpeedSlider_ValueChanged"/>
                        <ui:TextBlock x:Name="SpeedValueText" Grid.Column="2" Text="中 (12 字/秒)" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Width="90" TextAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
