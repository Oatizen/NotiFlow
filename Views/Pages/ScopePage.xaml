<Page x:Class="NotiFlow.Views.Pages.ScopePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewmodels="clr-namespace:NotiFlow.Models"
      xmlns:converters="clr-namespace:NotiFlow.Converters"
      Title="作用域"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <Page.DataContext>
        <viewmodels:ScopeViewModel />
    </Page.DataContext>

    <Page.Resources>
        <converters:BooleanToAppearanceConverter x:Key="BoolToAppearance" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Page.Resources>

    <Grid>
        <!-- 主滚动容器 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Margin="24,12,24,24" Background="Transparent">

                <!-- 顶部标题区 -->
                <Grid Margin="0,0,0,24">
                    <ui:TextBlock FontTypography="TitleLarge" Text="作用域" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon Search24}" ToolTip="搜索 (开发中)"/>
                    </StackPanel>
                </Grid>

                <!-- 选项卡切换区：使用 ui:Button + Command，与项目其他页面保持一致 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <ui:Button Content="生效场景" Command="{Binding SwitchToSceneCommand}" Margin="0,0,8,0" Padding="16,6">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSourceTabActive}" Value="False">
                                        <Setter Property="Appearance" Value="Primary" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button Content="通知来源" Command="{Binding SwitchToSourceCommand}" Margin="0,0,8,0" Padding="16,6">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSourceTabActive}" Value="True">
                                        <Setter Property="Appearance" Value="Primary" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <Grid Margin="0,0,0,0">
                        <ui:Button Appearance="Secondary" Padding="6" Icon="{ui:SymbolIcon QuestionCircle24}" Click="TopHelpButton_Click" VerticalAlignment="Center"/>
                        <ui:Flyout x:Name="TopHelpFlyout" Placement="Bottom">
                            <TextBlock Text="“生效场景”用于控制某些应用位于前台时是否显示弹幕，&#x0a;“通知来源”用于控制是否显示某些应用的通知" TextWrapping="Wrap" MaxWidth="300" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </ui:Flyout>
                    </Grid>
                </StackPanel>

                <!-- 模式切换区 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <ui:Button Content="排除模式" Command="{Binding SetModeCommand}" CommandParameter="Blacklist" Margin="0,0,8,0" Padding="16,6">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Blacklist">
                                        <Setter Property="Appearance" Value="Primary" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button Content="专注模式" Command="{Binding SetModeCommand}" CommandParameter="Whitelist" Margin="0,0,8,0" Padding="16,6">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Whitelist">
                                        <Setter Property="Appearance" Value="Primary" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button Content="全局显示" Command="{Binding SetModeCommand}" CommandParameter="Disabled" Margin="0,0,8,0" Padding="16,6">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Disabled">
                                        <Setter Property="Appearance" Value="Primary" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <Grid Margin="0,0,0,0">
                        <ui:Button Appearance="Secondary" Padding="6" Icon="{ui:SymbolIcon QuestionCircle24}" Click="BottomHelpButton_Click" VerticalAlignment="Center" />
                        <ui:Flyout x:Name="BottomHelpFlyout" Placement="Bottom">
                            <TextBlock TextWrapping="Wrap" MaxWidth="350" Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Text" Value="排除模式下，列表中的应用位于前台时不会显示弹幕&#x0a;专注模式下，只会在列表中的应用位于前台时显示弹幕&#x0a;全局显示时排除功能不生效"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSourceTabActive}" Value="True">
                                                <Setter Property="Text" Value="排除模式下，不会显示列表中应用的通知&#x0a;专注模式下，只会显示列表中应用的通知&#x0a;全局显示时排除功能不生效"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </ui:Flyout>
                    </Grid>
                </StackPanel>

                <!-- 全局显示时的提示文本 -->
                <TextBlock Text="已关闭过滤功能" HorizontalAlignment="Center" Margin="0,150,0,40"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="24" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentMode}" Value="Disabled">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 列表容器：仅在黑名单或白名单模式下显示 -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentMode}" Value="Disabled">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- 上方列表标题 -->
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="列表中的应用" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="状态 / 操作" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    </Grid>

                <!-- 上方列表：当前规则 -->
                <TextBlock Text="列表为空" HorizontalAlignment="Center" Margin="0,20,0,20"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RulesList.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding RulesList}" Margin="0,0,0,24">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 图标区域：真实图标叠放在占位图标之上 -->
                                    <Grid Grid.Column="0" Width="24" Height="24" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="AppFolder24" FontSize="20"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <Image Source="{Binding Icon}" Width="24" Height="24"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Detail}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:Button Appearance="Transparent"
                                                   Icon="{ui:SymbolIcon Copy24}"
                                                   Command="{Binding DataContext.CopyIdentifierCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding Identifier}"
                                                   ToolTip="复制标识符" Margin="0,0,4,0"/>
                                        <ui:Button Appearance="Transparent"
                                                   Icon="{ui:SymbolIcon Delete24}"
                                                   Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"
                                                   Foreground="Red" ToolTip="删除"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 分割线 -->
                <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,0,0,24"/>

                <!-- 下方列表标题 -->
                <Grid Margin="0,0,0,12">
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="正在运行的应用" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSourceTabActive}" Value="True">
                                        <Setter Property="Text" Value="近期通知的来源应用" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="操作" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                </Grid>

                <!-- 下方列表：可供添加的应用 -->
                <TextBlock Text="未找到可用项" HorizontalAlignment="Center" Margin="0,20,0,20"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AvailableList.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding AvailableList}" Margin="0,0,0,60">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 图标区域：真实图标叠放在占位图标之上 -->
                                        <Grid Grid.Column="0" Width="24" Height="24" VerticalAlignment="Center">
                                            <ui:SymbolIcon Symbol="AppFolder24" FontSize="20"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <Image Source="{Binding Icon}" Width="24" Height="24"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Detail}" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- 展开历史通知列表按钮 -->
                                            <ui:Button Command="{Binding ToggleExpandCommand}" Margin="0,0,8,0" Padding="6,4" ToolTip="显示历史通知">
                                                <ui:Button.Style>
                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                        <Setter Property="Appearance" Value="Secondary" />
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Appearance" Value="Primary" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RecentMessages.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                                <!-- 借助触发器，当按钮被选中（蓝底）时将箭头颜色变为白色 -->
                                                <ui:SymbolIcon Symbol="ChevronDown24" FontSize="16">
                                                    <ui:SymbolIcon.Style>
                                                        <Style TargetType="ui:SymbolIcon">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:SymbolIcon.Style>
                                                </ui:SymbolIcon>
                                            </ui:Button>

                                            <ui:Button Appearance="Transparent"
                                                       Icon="{ui:SymbolIcon Copy24}"
                                                       Command="{Binding DataContext.CopyIdentifierCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding Identifier}"
                                                       ToolTip="复制标识符" Margin="0,0,4,0"/>
                                            <ui:Button Appearance="Primary"
                                                       Icon="{ui:SymbolIcon Add24}"
                                                       Command="{Binding DataContext.AddRuleCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       ToolTip="添加"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 折叠展开的具体通知缓存列表 -->
                                    <Grid Margin="0,12,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 在图标正下方显示提示文字 -->
                                        <TextBlock Grid.Column="0" Text="历史&#x0a;通知" FontSize="10" TextAlignment="Center" 
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" Margin="0,6,0,0"/>

                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding RecentMessages}" Margin="8,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                        CornerRadius="4" Padding="8" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 右下角悬浮区 FAB及提示文本 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,32,32">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentMode}" Value="Disabled">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="没有找到需要的应用？试试手动添加" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="14" FontWeight="SemiBold"/>
            <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon Add24}"
                       Width="48" Height="48" CornerRadius="24"
                       Click="Fab_Click" ToolTip="手动添加标识符">
                <ui:Button.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.3" ShadowDepth="4" Color="Black"/>
                </ui:Button.Effect>
            </ui:Button>
        </StackPanel>
    </Grid>
</Page>
