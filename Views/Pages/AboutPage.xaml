<Page x:Class="NotiFlow.Views.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="关于"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent">
        <StackPanel Margin="24,12,24,24" HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="Transparent">
            
            <!-- 页面大标题 -->
            <Grid Margin="0,0,0,32">
                <ui:TextBlock FontTypography="TitleLarge" Text="关于我们" FontWeight="Bold"/>
                <ui:Button Appearance="Primary" Content="反馈问题" HorizontalAlignment="Right" VerticalAlignment="Center" Click="Feedback_Click"/>
            </Grid>

            <!-- 应用信息卡片 -->
            <Border Margin="0,0,0,32" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左侧大 Logo -->
                    <Image Grid.Column="0" Source="/NotiFlow Icon.png" Width="140" Height="140" Stretch="Uniform" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    
                    <!-- 右侧详情与操作 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:TextBlock Text="弹幕通知" FontTypography="Title" FontWeight="SemiBold" Margin="0,0,12,0"/>
                            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="12" Padding="8,2" VerticalAlignment="Center">
                                <ui:TextBlock x:Name="VersionTextBase" Text="V1.0.0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                        
                        <ui:TextBlock Text="一款将 Windows 通知以弹幕形式叠加在屏幕上的通知显示工具，为您创造非侵入式的信息流。" 
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                      TextWrapping="Wrap" 
                                      Margin="0,0,0,16"/>
                                      
                        <WrapPanel Orientation="Horizontal">
                            <ui:Button Appearance="Primary" Content="GitHub 仓库" Icon="{ui:SymbolIcon Branch24}" Margin="0,0,12,12" Click="GitHubGo_Click"/>
                            <ui:Button Appearance="Primary" Content="检查更新" Icon="{ui:SymbolIcon ArrowSync24}" Margin="0,0,12,12" Click="CheckUpdate_Click"/>
                            <ui:Button Appearance="Secondary" Content="许可证" Icon="{ui:SymbolIcon Document24}" Margin="0,0,0,12" Click="LicenseGo_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 高级选项面板 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <ui:SymbolIcon Symbol="Wrench24" FontSize="20" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" Margin="0,0,8,0"/>
                <ui:TextBlock Text="高级设置" FontTypography="BodyStrong"/>
            </StackPanel>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 导入设置 -->
                <ui:Button Grid.Column="0" Height="100" HorizontalAlignment="Stretch" CornerRadius="12" Click="Import_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="24" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                        <ui:TextBlock Text="导入设置" FontTypography="BodyStrong" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>

                <!-- 导出设置 -->
                <ui:Button Grid.Column="2" Height="100" HorizontalAlignment="Stretch" CornerRadius="12" Click="Export_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="24" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                        <ui:TextBlock Text="导出设置" FontTypography="BodyStrong" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>

                <!-- 重置设置 -->
                <ui:Button Grid.Column="4" Height="100" HorizontalAlignment="Stretch" CornerRadius="12" Click="Reset_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="24" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                        <ui:TextBlock Text="重置设置" FontTypography="BodyStrong" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
