<Page x:Class="NotiFlow.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="设置"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent">
        <StackPanel Margin="24,12,24,24" HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="Transparent">
            
            <!-- 页面大标题 -->
            <Grid Margin="0,0,0,32">
                <ui:TextBlock FontTypography="TitleLarge" Text="设置" FontWeight="Bold"/>
                <ui:Button Appearance="Primary" Content="检查更新" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- 快捷键区块 -->
            <ui:TextBlock Text="快捷键" FontTypography="BodyStrong" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Margin="0,0,0,32" Padding="16">
                <Grid>
                    <ui:TextBlock Text="切换弹幕显示" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Right" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ui:TextBlock Text="Ctrl + Shift + D" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,24,0"/>
                            <ui:SymbolIcon Symbol="Keyboard24" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 界面区块 -->
            <ui:TextBlock Text="界面" FontTypography="BodyStrong" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Margin="0,0,0,32" Padding="16">
                <StackPanel>
                    <!-- 语言 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="LocalLanguage24" FontSize="18"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <ui:TextBlock Text="语言" FontTypography="BodyStrong"/>
                            <ui:TextBlock Text="选择您偏好的显示语言" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="2" SelectedIndex="0" VerticalAlignment="Center" Width="150" HorizontalAlignment="Right">
                            <ComboBoxItem Content="简体中文"/>
                        </ComboBox>
                    </Grid>

                    <!-- 主题 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="WeatherMoon24" FontSize="18"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <ui:TextBlock Text="主题" FontTypography="BodyStrong"/>
                            <ui:TextBlock Text="个性化您的工作区外观" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ComboBox x:Name="ThemeComboBox" Grid.Column="2" SelectedIndex="1" VerticalAlignment="Center" Width="150" HorizontalAlignment="Right" SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="系统默认"/>
                            <ComboBoxItem Content="浅色"/>
                            <ComboBoxItem Content="深色"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 行为区块 -->
            <ui:TextBlock Text="行为" FontTypography="BodyStrong" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel>
                    <!-- 以管理员身份运行 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Shield24" FontSize="18"/>
                        </Border>
                        <ui:TextBlock Grid.Column="1" Text="以管理员身份运行" VerticalAlignment="Center"/>
                        <ui:ToggleSwitch Grid.Column="2" IsChecked="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 应用启动时自动工作 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Play24" FontSize="18"/>
                        </Border>
                        <ui:TextBlock Grid.Column="1" Text="应用启动时自动工作" VerticalAlignment="Center"/>
                        <ui:ToggleSwitch Grid.Column="2" IsChecked="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 开机自启动 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Rocket24" FontSize="18"/>
                        </Border>
                        <ui:TextBlock Grid.Column="1" Text="开机自启动" VerticalAlignment="Center"/>
                        <ui:ToggleSwitch Grid.Column="2" IsChecked="False" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 最小化到系统托盘 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="ArrowMinimize24" FontSize="18"/>
                        </Border>
                        <ui:TextBlock Grid.Column="1" Text="最小化到系统托盘" VerticalAlignment="Center"/>
                        <ui:ToggleSwitch Grid.Column="2" IsChecked="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 关闭到系统托盘 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="DismissSquare24" FontSize="18"/>
                        </Border>
                        <ui:TextBlock Grid.Column="1" Text="关闭到系统托盘" VerticalAlignment="Center"/>
                        <ui:ToggleSwitch Grid.Column="2" IsChecked="True" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
